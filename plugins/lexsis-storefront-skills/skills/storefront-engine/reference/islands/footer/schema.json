{
  "name": "Footer",
  "category": "navigation",
  "usage_hint": "Site-wide footer with links, logo, newsletter signup, social icons, and copyright. Always placed at bottom of page.",
  "when_to_use": "Every page needs a footer. Supports multiple layouts (simple, columns, centered, editorialGrid, newsletterSplit) and both hydration mode (custom HTML with data-lx-footer tags) and legacy mode (React-rendered). Newsletter form auto-submits to configured endpoint.",
  "when_not_to_use": "For minimal page templates without site-wide footer (rare). For mid-page newsletter blocks use a dedicated newsletter island.",
  "combine_with": [
    "Navbar",
    "SiteHeader",
    "BackToTop"
  ],
  "anti_patterns": [
    "Using multiple Footer instances on one page \u2014 there should be one site-wide footer",
    "Hardcoding current year instead of using data-lx-footer=\"year\" (hydration) or letting the component auto-fill it",
    "Duplicating social links in both Footer and separate social bar (pick one location)"
  ],
  "examples": [
    {
      "label": "Hydration mode with newsletter form",
      "html": "<div data-island=\"Footer\" data-props='{\"newsletterEndpoint\":\"/api/newsletter\",\"successMessage\":\"Thanks!\"}'><footer data-lx-footer=\"root\"><form data-lx-footer=\"newsletter-form\"><input data-lx-footer=\"newsletter-input\" type=\"email\"/><button>Subscribe</button></form><div data-lx-footer=\"newsletter-success\" style=\"display:none;\"></div><p>&copy; <span data-lx-footer=\"year\"></span> All rights reserved.</p></footer></div>"
    },
    {
      "label": "Legacy simple layout",
      "html": "<div data-island=\"Footer\" data-props='{\"links\":[{\"label\":\"Privacy\",\"url\":\"/privacy\"},{\"label\":\"Terms\",\"url\":\"/terms\"}],\"logo\":{\"src\":\"/logo.svg\"},\"copyright\":\"\u00a9 2026 Store\",\"socialLinks\":[{\"platform\":\"instagram\",\"url\":\"https://instagram.com/store\"}]}'></div>"
    },
    {
      "label": "Legacy columns layout with newsletter",
      "html": "<div data-island=\"Footer\" data-props='{\"columns\":[{\"heading\":\"Shop\",\"links\":[{\"label\":\"New Arrivals\",\"url\":\"/new\"},{\"label\":\"Sale\",\"url\":\"/sale\"}]},{\"heading\":\"Help\",\"links\":[{\"label\":\"FAQ\",\"url\":\"/faq\"},{\"label\":\"Shipping\",\"url\":\"/shipping\"}]}],\"newsletter\":{\"heading\":\"Stay Updated\",\"placeholder\":\"Your email\",\"buttonText\":\"Subscribe\"},\"style\":{\"layout\":\"columns\"}}'></div>"
    }
  ],
  "props": {
    "links": {
      "type": "array",
      "required": true,
      "shape": {
        "label": "string",
        "url": "string"
      }
    },
    "columns": {
      "type": "array",
      "required": false,
      "shape": {
        "heading": "?string",
        "links": "array<{label: string, url: string}>"
      }
    },
    "logo": {
      "type": "object",
      "required": false,
      "shape": {
        "src": "string",
        "alt": "?string"
      }
    },
    "copyright": {
      "type": "string",
      "required": false
    },
    "tagline": {
      "type": "string",
      "required": false
    },
    "socialLinks": {
      "type": "array",
      "required": false,
      "shape": {
        "platform": "string",
        "url": "string",
        "icon": "?string"
      }
    },
    "style": {
      "type": "object",
      "required": false,
      "shape": {
        "bgColor": "?string",
        "textColor": "?string",
        "linkColor": "?string",
        "linkHoverColor": "?string",
        "headingColor": "?string",
        "accentColor": "?string",
        "borderColor": "?string",
        "fontFamily": "?string",
        "fontSize": "?string",
        "padding": "?string",
        "maxWidth": "?string",
        "logoHeight": "?string",
        "layout": "?'simple' | 'columns' | 'centered' | 'editorialGrid' | 'newsletterSplit'"
      }
    },
    "newsletter": {
      "type": "object",
      "required": false,
      "shape": {
        "heading": "?string",
        "placeholder": "?string",
        "buttonText": "?string"
      }
    },
    "borderStyle": {
      "type": "enum",
      "required": false,
      "values": [
        "none",
        "solid",
        "dashed"
      ]
    },
    "tileLayout": {
      "type": "boolean",
      "required": false
    }
  },
  "variants": null,
  "css_vars": [
    "--lx-accent-color"
  ],
  "parts": [
    "nav-rows",
    "newsletter",
    "root",
    "social-tiles"
  ],
  "example": "<div data-island=\"Footer\" data-props='{\"links\":[{\"label\":\"example-label\",\"url\":\"example-url\"}]}'></div>"
}
