{
  "id": "cart-bottom-sheet",
  "html": "<div data-island=\"DrawerShell\" data-island-container data-props='{\"mode\":\"bottom-sheet\",\"trigger\":\"cart:open\",\"maxHeight\":\"85vh\"}'><div class=\"flex flex-col h-full\"><div class=\"flex-shrink-0 px-5 pt-4 pb-3 border-b\" style=\"border-color: var(--lx-border-color)\"><div class=\"w-10 h-1 rounded-full bg-gray-300 mx-auto mb-3\"></div><div data-island=\"CartProgressBar\" data-props='{}'></div></div><div class=\"flex-1 overflow-y-auto px-5 py-3\"><div data-island=\"CartLines\" data-props='{\"layout\":\"compact\",\"showQuantity\":true,\"showRemove\":true}'></div><div data-island=\"CartCrossSell\" data-props='{}'></div></div><div class=\"flex-shrink-0 px-5 pb-5 pt-3 border-t space-y-3\" style=\"border-color: var(--lx-border-color)\"><div data-island=\"CartSummary\" data-props='{\"showDiscounts\":true}'></div><div data-island=\"CartCheckoutButton\" data-props='{\"text\":\"Checkout\",\"style\":\"filled\"}'></div></div></div></div>",
