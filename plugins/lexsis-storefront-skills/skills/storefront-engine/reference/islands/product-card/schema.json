{
  "name": "ProductCard",
  "category": "commerce",
  "usage_hint": "Product card for collection pages and grids. Displays product media, title, price, optional badge, and interactive features (quick-add, wishlist, quick-view). Wraps ProductCard primitive.",
  "when_to_use": "Use in collection grids, product carousels, related product sections, search results. Provides full product preview with optional add-to-cart and wishlist actions.",
  "when_not_to_use": "Not for PDP main product display (use BuyBox + ProductGallery/ProductHero). Not for lightweight inline add-to-cart (use QuickAdd island directly).",
  "combine_with": [
    "CartDrawer (REQUIRED if showQuickAdd:true)",
    "ProductCarousel (for horizontal scrolling)",
    "EditorialProductGrid (for curated layouts)"
  ],
  "anti_patterns": [
    "Using showQuickAdd:true without CartDrawer: users get no cart feedback",
    "Setting hoverAdvance:true with single media: no hover effect, wastes prop",
    "Using variant:\"horizontal\" in narrow grids: card will overflow or look cramped",
    "Missing media array: card will render empty or broken"
  ],
  "examples": [
    {
      "label": "Default product card with quick-add",
      "html": "<div data-island=\"ProductCard\" data-props='{\"product\":{\"id\":\"p1\",\"handle\":\"wireless-headphones\",\"title\":\"Wireless Headphones\",\"price\":\"$99.00\",\"compareAtPrice\":\"$129.00\",\"variants\":[{\"id\":\"v1\",\"title\":\"Black\",\"price\":\"$99.00\",\"available\":true}],\"media\":[{\"src\":\"https://via.placeholder.com/400\",\"alt\":\"Product image\"}]},\"showQuickAdd\":true,\"showLearnMore\":true}'></div>"
    },
    {
      "label": "Compact card with badge",
      "html": "<div data-island=\"ProductCard\" data-props='{\"product\":{\"id\":\"p2\",\"handle\":\"t-shirt\",\"title\":\"Premium T-Shirt\",\"price\":\"$29.00\",\"variants\":[{\"id\":\"v1\",\"title\":\"Medium\",\"price\":\"$29.00\",\"available\":true}],\"media\":[{\"src\":\"https://via.placeholder.com/400\"}]},\"badge\":\"New\",\"badgeColor\":\"#ff5555\",\"variant\":\"compact\"}'></div>"
    },
    {
      "label": "Horizontal card with wishlist",
      "html": "<div data-island=\"ProductCard\" data-props='{\"product\":{\"id\":\"p3\",\"handle\":\"sneakers\",\"title\":\"Running Sneakers\",\"price\":\"$120.00\",\"variants\":[{\"id\":\"v1\",\"title\":\"Size 10\",\"price\":\"$120.00\",\"available\":true}],\"media\":[{\"src\":\"https://via.placeholder.com/400\"}]},\"variant\":\"horizontal\",\"showWishlist\":true,\"showQuickView\":true}'></div>"
    },
    {
      "label": "Card with media hover advance",
      "html": "<div data-island=\"ProductCard\" data-props='{\"product\":{\"id\":\"p4\",\"handle\":\"watch\",\"title\":\"Smartwatch\",\"price\":\"$299.00\",\"variants\":[{\"id\":\"v1\",\"title\":\"Silver\",\"price\":\"$299.00\",\"available\":true}],\"media\":[{\"src\":\"https://via.placeholder.com/400\"},{\"src\":\"https://via.placeholder.com/400\"}]},\"mediaTransition\":\"fade\",\"hoverAdvance\":true}'></div>"
    }
  ],
  "props": {
    "product": {
      "type": "object",
      "required": true,
      "shape": {
        "id": "string",
        "handle": "string",
        "title": "string",
        "price": "string",
        "compareAtPrice": "?string",
        "variants": "array<{id: string, title: string, price: string, available: boolean}>",
        "media": "array<{src: string, alt: ?string, poster: ?string}>"
      }
    },
    "badge": {
      "type": "string",
      "required": false
    },
    "badgeColor": {
      "type": "string",
      "required": false
    },
    "showQuickAdd": {
      "type": "boolean",
      "required": false
    },
    "showWishlist": {
      "type": "boolean",
      "required": false
    },
    "showLearnMore": {
      "type": "boolean",
      "required": false
    },
    "showQuickView": {
      "type": "boolean",
      "required": false
    },
    "learnMoreText": {
      "type": "string",
      "required": false
    },
    "mediaTransition": {
      "type": "enum",
      "required": false,
      "values": [
        "none",
        "fade",
        "slide",
        "zoom",
        "kenBurns"
      ]
    },
    "hoverAdvance": {
      "type": "boolean",
      "required": false
    },
    "variant": {
      "type": "enum",
      "required": false,
      "values": [
        "horizontal",
        "default",
        "compact"
      ]
    },
    "className": {
      "type": "string",
      "required": false
    }
  },
  "variants": [
    "horizontal",
    "default",
    "compact"
  ],
  "css_vars": [],
  "parts": [
    "badge",
    "image",
    "price",
    "quick-add",
    "root",
    "title"
  ],
  "example": "<div data-island=\"ProductCard\" data-props='{\"product\":{\"id\":\"example-id\",\"handle\":\"example-handle\",\"title\":\"example-title\",\"price\":\"example-price\",\"variants\":[],\"media\":[]}}'></div>"
}
