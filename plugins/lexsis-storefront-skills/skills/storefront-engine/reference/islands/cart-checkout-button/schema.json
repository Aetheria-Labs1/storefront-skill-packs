{
  "name": "CartCheckoutButton",
  "category": "commerce",
  "usage_hint": "Checkout CTA button that navigates to the Shopify checkout URL. Subscribes to shared cart state.",
  "when_to_use": "Inside DrawerShell below CartSummary as the primary cart action button.",
  "when_not_to_use": "Outside cart context. For generic CTAs use a plain link or button element.",
  "combine_with": [
    "DrawerShell",
    "CartSummary",
    "CartLines"
  ],
  "anti_patterns": [],
  "examples": [],
  "props": {
    "text": {
      "type": "string",
      "required": false,
      "default": "Checkout"
    },
    "style": {
      "type": "enum",
      "required": false,
      "values": [
        "filled",
        "outline"
      ],
      "default": "filled"
    },
    "secondaryCta": {
      "type": "object",
      "required": false,
      "shape": {
        "label": "string",
        "url": "string"
      }
    },
    "showCartCount": {
      "type": "boolean",
      "required": false,
      "default": "false"
    }
  },
  "variants": [
    "filled",
    "outline"
  ],
  "css_vars": [
    "--lx-accent-color"
  ],
  "parts": [
    "cta",
    "root",
    "secondary-cta"
  ],
  "example": "<div data-island=\"CartCheckoutButton\" data-props='{}'></div>"
