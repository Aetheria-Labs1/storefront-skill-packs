{
  "name": "StatCards",
  "category": "social_proof",
  "usage_hint": "Animated stat cards that count up on scroll. Renders percentage/number statistics with configurable layout (vertical/horizontal/inline) and visual style (glass/solid/gradient/headless). Ideal as overlay cards on hero sections or standalone social proof rows.",
  "when_to_use": "For displaying key metrics (conversion rates, customer counts, satisfaction scores, revenue figures) that benefit from scroll-triggered count-up animation. Use on hero overlays, trust sections, or above-the-fold proof points where animated numbers draw attention and reinforce credibility.",
  "when_not_to_use": "For static numbers that don't need animation (use plain HTML). For live/real-time data that updates continuously (use a dashboard widget). For single isolated stats (overkill — use inline text). For very long numbers (>7 digits) that are hard to read during animation.",
  "defaultHydrate": "visible",
  "combine_with": [
    "HeroMedia",
    "TrustBadgeBar",
    "SocialProofPopup"
  ],
  "anti_patterns": [
    "Too many items (>6): overwhelming and dilutes impact — pick top 3-4 metrics",
    "Placing below fold where animation isn't seen on first load (defeats the purpose of count-up)",
    "Using with animate:false AND glass style (static glass cards look like broken UI without the reveal)",
    "Decimal values with long suffixes (e.g. 99.87% satisfaction) — round for impact",
    "Using gradient style on dark backgrounds without adjusting --lx-stat-gradient (gradient may be invisible)"
  ],
  "examples": [
    {
      "label": "Glass overlay on hero (3 stats)",
      "html": "<div data-island=\"StatCards\" data-props='{\"items\":[{\"value\":98,\"suffix\":\"%\",\"label\":\"Customer Satisfaction\"},{\"value\":50,\"suffix\":\"k+\",\"label\":\"Happy Customers\"},{\"value\":4.9,\"label\":\"Average Rating\",\"sublabel\":\"Based on 12,000+ reviews\"}],\"layout\":\"horizontal\",\"style\":\"glass\"}'></div>"
    },
    {
      "label": "Solid row with stagger",
      "html": "<div data-island=\"StatCards\" data-props='{\"items\":[{\"value\":250,\"suffix\":\"+\",\"label\":\"Brands Trust Us\"},{\"value\":99.9,\"suffix\":\"%\",\"label\":\"Uptime\"},{\"value\":24,\"suffix\":\"/7\",\"label\":\"Support\"}],\"layout\":\"horizontal\",\"style\":\"solid\",\"stagger\":300}'></div>"
    },
    {
      "label": "Gradient numbers inline",
      "html": "<div data-island=\"StatCards\" data-props='{\"items\":[{\"prefix\":\"$\",\"value\":2.5,\"suffix\":\"M\",\"label\":\"Revenue Generated\"},{\"value\":150,\"suffix\":\"%\",\"label\":\"Average ROI\"}],\"layout\":\"inline\",\"style\":\"gradient\"}'></div>"
    },
    {
      "label": "Headless (fully section-styled)",
      "html": "<div data-island=\"StatCards\" data-props='{\"items\":[{\"value\":10000,\"suffix\":\"+\",\"label\":\"Products Shipped\"},{\"value\":48,\"label\":\"Hours Avg Delivery\"}],\"style\":\"headless\"}'></div>"
    }
  ],
  "props": {
    "items": {
      "type": "array",
      "required": true,
      "items": {
        "type": "object",
        "shape": {
          "value": "number (required)",
          "suffix": "?string (e.g. '%', '+', 'k', 'M')",
          "prefix": "?string (e.g. '$', '#')",
          "label": "string (required)",
          "sublabel": "?string"
        }
      }
    },
    "layout": {
      "type": "enum",
      "required": false,
      "values": ["vertical", "horizontal", "inline"],
      "default": "horizontal"
    },
    "style": {
      "type": "enum",
      "required": false,
      "values": ["glass", "solid", "gradient", "headless"],
      "default": "glass"
    },
    "animate": {
      "type": "boolean",
      "required": false,
      "default": true
    },
    "duration": {
      "type": "number",
      "required": false,
      "default": 2000
    },
    "threshold": {
      "type": "number",
      "required": false,
      "default": 0.3
    },
    "stagger": {
      "type": "number",
      "required": false,
      "default": 200
    }
  },
  "variants": [
    "glass",
    "solid",
    "gradient",
    "headless"
  ],
  "css_vars": [
    "--lx-stat-bg",
    "--lx-stat-blur",
    "--lx-stat-border",
    "--lx-stat-gap",
    "--lx-stat-gradient",
    "--lx-stat-label-color",
    "--lx-stat-number-color",
    "--lx-stat-number-size",
    "--lx-stat-padding",
    "--lx-stat-radius",
    "--lx-stat-sublabel-color"
  ],
  "parts": [
    "item",
    "label",
    "number",
    "prefix",
    "root",
    "sublabel",
    "suffix"
  ],
  "example": "<div data-island=\"StatCards\" data-props='{\"items\":[{\"value\":98,\"suffix\":\"%\",\"label\":\"Satisfaction\"}]}'></div>"
}
