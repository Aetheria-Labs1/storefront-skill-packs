{
  "name": "OptionResolver",
  "category": "commerce",
  "usage_hint": "Invisible resolver that listens for option:changed events and emits variant:changed with matched variant data (price, image, availability).",
  "when_to_use": "On product pages with multiple options (size, color, etc.). Place alongside VariantSelector islands. This island has no UI \u2014 it's pure logic that coordinates option selections into a resolved variant.",
  "when_not_to_use": "For single-variant products (no options). When BuyBox already handles variant resolution internally. Don't use multiple OptionResolvers on one page.",
  "combine_with": [
    "VariantSelector",
    "BuyBox",
    "ProductPrice",
    "ProductImage",
    "InventoryIndicator (all listen for variant:changed)"
  ],
  "anti_patterns": [
    "Providing incomplete variant data (missing selectedOptions) \u2014 resolver can't match",
    "Using without VariantSelector islands to emit option:changed (nothing will trigger it)",
    "Expecting OptionResolver to validate inventory \u2014 it only matches, use InventoryIndicator for stock checks"
  ],
  "examples": [
    {
      "label": "Basic size + color resolver",
      "html": "<div data-island=\"OptionResolver\" data-props='{\"variants\":[{\"id\":\"v1\",\"selectedOptions\":[{\"name\":\"Size\",\"value\":\"Small\"},{\"name\":\"Color\",\"value\":\"Red\"}],\"price\":\"$29.99\",\"available\":true,\"image\":\"/red-small.jpg\"},{\"id\":\"v2\",\"selectedOptions\":[{\"name\":\"Size\",\"value\":\"Medium\"},{\"name\":\"Color\",\"value\":\"Blue\"}],\"price\":\"$29.99\",\"available\":false}],\"options\":[{\"name\":\"Size\",\"position\":1},{\"name\":\"Color\",\"position\":2}]}'></div>"
    },
    {
      "label": "With default selections",
      "html": "<div data-island=\"OptionResolver\" data-props='{\"variants\":[{\"id\":\"v10\",\"selectedOptions\":[{\"name\":\"Size\",\"value\":\"Large\"}],\"price\":\"$49.99\",\"available\":true}],\"options\":[{\"name\":\"Size\",\"position\":1}],\"defaultSelections\":{\"Size\":\"Large\"}}'></div>"
    },
    {
      "label": "Complex multi-option product",
      "html": "<div data-island=\"OptionResolver\" data-props='{\"variants\":[{\"id\":\"v20\",\"selectedOptions\":[{\"name\":\"Material\",\"value\":\"Cotton\"},{\"name\":\"Size\",\"value\":\"M\"},{\"name\":\"Color\",\"value\":\"Navy\"}],\"price\":\"$39.99\",\"compareAtPrice\":\"$59.99\",\"available\":true,\"images\":[{\"url\":\"/navy-m.jpg\"}]}],\"options\":[{\"name\":\"Material\",\"position\":1},{\"name\":\"Size\",\"position\":2},{\"name\":\"Color\",\"position\":3}]}'></div>"
    }
  ],
  "props": {
    "variants": {
      "type": "array",
      "required": true,
      "shape": {
        "id": "string",
        "selectedOptions": "array<{name: string, value: string}>",
        "price": "string",
        "compareAtPrice": "?string",
        "available": "boolean",
        "image": "?string",
        "images": "?array<{url: string, alt: ?string}>"
      }
    },
    "options": {
      "type": "array",
      "required": true,
      "shape": {
        "name": "string",
        "position": "number"
      }
    },
    "defaultSelections": {
      "type": "object",
      "required": false,
      "shape": {}
    }
  },
  "variants": null,
  "css_vars": [],
  "parts": [],
  "example": "<div data-island=\"OptionResolver\" data-props='{\"variants\":[{\"id\":\"example-id\",\"selectedOptions\":\"example-selectedOptions\",\"price\":\"example-price\",\"available\":true}],\"options\":[{\"name\":\"example-name\",\"position\":0}]}'></div>"
}
