{
  "id": "cart-drawer-right",
  "html": "<section class=\"hidden\"><div data-island=\"DrawerShell\" data-props='{\"position\":\"right\",\"triggerId\":\"cart-icon\",\"width\":\"420px\",\"overlay\":true}'><div class=\"flex flex-col h-full\"><div class=\"flex-shrink-0 px-6 pt-6 pb-4 border-b\" style=\"border-color: var(--lx-border-color)\"><div data-island=\"CartProgressBar\" data-props='{\"threshold\":{{FREE_SHIPPING_THRESHOLD}},\"labelBelow\":\"Free shipping on orders over ${{FREE_SHIPPING_THRESHOLD}}\",\"labelReached\":\"You qualify for free shipping!\",\"accentColor\":\"var(--lx-accent-color)\",\"height\":\"8px\"}'></div></div><div class=\"flex-1 overflow-y-auto px-6 py-4\"><div data-island=\"CartLines\" data-props='{\"variant\":\"full\",\"showQuantityControls\":true,\"showRemoveButton\":true,\"showVariantInfo\":true,\"showImages\":true,\"imageSize\":\"64px\"}'></div></div><div class=\"flex-shrink-0 px-6 pb-6 pt-4 border-t space-y-4\" style=\"border-color: var(--lx-border-color)\"><div data-island=\"CartSummary\" data-props='{\"showSubtotal\":true,\"showShipping\":true,\"showTax\":false,\"currency\":\"USD\"}'></div><div data-island=\"CartCheckoutButton\" data-props='{\"variant\":\"filled\",\"text\":\"{{CTA_TEXT}}\",\"fullWidth\":true,\"size\":\"lg\"}'></div></div></div></div></section>",
  "css": "",
  "js": ""
}
