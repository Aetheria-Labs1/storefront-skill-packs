{
  "id": "cart-bottom-sheet",
  "html": "<section class=\"hidden\"><div data-island=\"DrawerShell\" data-props='{\"position\":\"bottom\",\"triggerId\":\"cart-icon\",\"responsive\":{\"mobile\":\"bottom-sheet\"},\"overlay\":true,\"maxHeight\":\"85vh\"}'><div class=\"flex flex-col h-full\"><div class=\"flex-shrink-0 px-5 pt-4 pb-3 border-b\" style=\"border-color: var(--lx-border-color)\"><div class=\"w-10 h-1 rounded-full bg-gray-300 mx-auto mb-3\"></div><div data-island=\"CartProgressBar\" data-props='{\"threshold\":{{FREE_SHIPPING_THRESHOLD}},\"labelBelow\":\"Add more for free shipping\",\"labelReached\":\"Free shipping unlocked!\",\"accentColor\":\"var(--lx-accent-color)\",\"height\":\"6px\"}'></div></div><div class=\"flex-1 overflow-y-auto px-5 py-3\"><div data-island=\"CartLines\" data-props='{\"variant\":\"compact\",\"showQuantityControls\":true,\"showRemoveButton\":true,\"showVariantInfo\":false,\"showImages\":true,\"imageSize\":\"48px\"}'></div></div><div class=\"flex-shrink-0 px-5 pb-5 pt-3 border-t space-y-3\" style=\"border-color: var(--lx-border-color)\"><div data-island=\"CartSummary\" data-props='{\"showSubtotal\":true,\"showShipping\":true,\"showTax\":false,\"currency\":\"USD\"}'></div><div data-island=\"CartCheckoutButton\" data-props='{\"variant\":\"filled\",\"text\":\"{{CTA_TEXT}}\",\"fullWidth\":true,\"size\":\"lg\"}'></div></div></div></div></section>",
  "css": "",
  "js": ""
}
