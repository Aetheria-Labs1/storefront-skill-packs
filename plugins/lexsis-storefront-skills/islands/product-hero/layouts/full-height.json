{
  "id": "hero",
  "html": "<section class=\"w-full min-h-screen relative flex items-center justify-center\" style=\"background-color: var(--lx-bg-color)\"><div class=\"absolute inset-0\"><img src=\"{{IMAGE_URL}}\" alt=\"{{HEADLINE}}\" class=\"w-full h-full object-cover\" /><div class=\"absolute inset-0\" style=\"background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 50%, transparent 100%)\"></div></div><div class=\"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20\"><div class=\"max-w-3xl mx-auto space-y-6\"><h1 class=\"text-4xl md:text-5xl lg:text-6xl font-bold text-white\" style=\"font-family: var(--lx-font-heading)\">{{HEADLINE}}</h1><p class=\"text-lg text-white/80\">{{SUBHEADLINE}}</p><div data-island=\"ProductHero\" data-props='{\"productId\":\"{{PRODUCT_ID}}\",\"variant\":\"fullHeight\",\"ctaText\":\"{{CTA_TEXT}}\",\"showPrice\":true,\"darkMode\":true}'></div></div></div></section>",
