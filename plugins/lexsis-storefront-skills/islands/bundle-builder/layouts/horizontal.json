{
  "id": "bundle-horizontal",
  "html": "<section class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16 lg:py-20\"><div class=\"text-center mb-8 md:mb-12\"><h2 class=\"text-2xl md:text-3xl lg:text-4xl font-bold\" style=\"font-family: var(--lx-font-heading); color: var(--lx-text-color)\">Bundle & Save</h2><p class=\"mt-3 text-lg max-w-2xl mx-auto\" style=\"color: var(--lx-text-muted)\">Mix and match your favorites for exclusive discounts</p></div><div class=\"grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-8 lg:gap-12 items-start\"><div data-island=\"BundleBuilder\" data-props='{\"variant\":\"horizontal\",\"productIds\":{{PRODUCT_IDS}},\"discountTiers\":{{DISCOUNT_TIERS}},\"ctaText\":\"{{CTA_TEXT}}\",\"showProgress\":true,\"maxItems\":6}'></div><div class=\"lg:sticky lg:top-24 lg:self-start rounded-xl border p-6\" style=\"border-color: var(--lx-border-color); background-color: var(--lx-bg-surface)\"><h3 class=\"text-lg font-semibold mb-4\" style=\"color: var(--lx-text-color)\">Your Bundle</h3><div class=\"space-y-3 mb-4\"><div class=\"text-sm\" style=\"color: var(--lx-text-muted)\">Selected items will appear here</div></div><div class=\"border-t pt-4 space-y-2\" style=\"border-color: var(--lx-border-color)\"><div class=\"flex justify-between text-sm\"><span style=\"color: var(--lx-text-muted)\">Subtotal</span><span style=\"color: var(--lx-text-color)\">—</span></div><div class=\"flex justify-between text-sm font-semibold\"><span style=\"color: var(--lx-accent-color)\">Bundle Discount</span><span style=\"color: var(--lx-accent-color)\">—</span></div></div></div></div></section>",
