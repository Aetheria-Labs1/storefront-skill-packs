{
  "id": "footer-editorial-grid",
  "html": "<footer class=\"w-full py-16\" style=\"background-color: var(--lx-surface-alt)\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"grid grid-cols-1 lg:grid-cols-[1.5fr_1fr_1fr_1fr] gap-12 lg:gap-8\"><div class=\"space-y-4\"><img src=\"{{LOGO_URL}}\" alt=\"{{BRAND_NAME}}\" class=\"h-8 w-auto\" /><p class=\"text-sm max-w-xs\" style=\"color: var(--lx-text-muted)\">Quality products crafted with care. Elevating your everyday experience.</p></div><div data-island=\"Footer\" data-props='{\"logo\":{\"src\":\"{{LOGO_URL}}\",\"alt\":\"{{BRAND_NAME}}\"},\"columns\":{{COLUMNS}},\"socialLinks\":{{SOCIAL_LINKS}},\"style\":{\"variant\":\"editorial-grid\"},\"newsletter\":{\"enabled\":false}}'></div></div><div class=\"mt-12 pt-8 border-t flex flex-col sm:flex-row items-center justify-between gap-4\" style=\"border-color: var(--lx-border-color)\"><div class=\"flex items-center gap-4\"><div data-island=\"SocialIcons\" data-props='{\"links\":{{SOCIAL_LINKS}},\"size\":\"sm\"}'></div></div><p class=\"text-xs\" style=\"color: var(--lx-text-muted)\">&copy; {{COPYRIGHT_YEAR}} {{BRAND_NAME}}. All rights reserved.</p></div></div></footer>",
