{
  "name": "VariantSelector",
  "category": "unknown",
  "usage_hint": "Visual variant/option selector that emits scoped variant:changed events. Supports swatches, dropdown, and button pill modes. For headless (no UI) selection, use data-behavior=\"variant-select\" instead.",
  "when_to_use": "Use inside custom product cards, quick-view modals, or anywhere you need visual variant selection with automatic event emission. Pairs with QuickAdd for full add-to-cart flow.",
  "when_not_to_use": "Not for PDP (BuyBox handles variant selection). Not for headless coordination only (use data-behavior=\"variant-select\"). Not when you need full product gallery image switching (use ProductGallery).",
  "defaultHydrate": "immediate",
  "combine_with": [
    "QuickAdd (add-to-cart after selection)",
    "MediaCarousel (switch images on variant change)",
    "CartDrawer (cart feedback)"
  ],
  "anti_patterns": [
    "Using without data-scope when multiple VariantSelectors on page (events will collide)",
    "Using render:\"swatches\" for non-color options (confusing UX \u2014 use \"buttons\" for sizes)",
    "Providing variants without options array (selector won't know axis names)"
  ],
  "examples": [
    {
      "label": "Color swatches",
      "html": "<div data-scope=\"product:p1\" data-island=\"VariantSelector\" data-props='{\"product\":{\"variants\":[{\"id\":\"v1\",\"title\":\"Black / M\",\"price\":\"$49\",\"available\":true,\"options\":{\"Color\":\"Black\",\"Size\":\"M\"}},{\"id\":\"v2\",\"title\":\"White / M\",\"price\":\"$49\",\"available\":true,\"options\":{\"Color\":\"White\",\"Size\":\"M\"}}],\"options\":[{\"name\":\"Color\",\"values\":[\"Black\",\"White\"]},{\"name\":\"Size\",\"values\":[\"M\",\"L\"]}]},\"render\":\"swatches\"}'></div>"
    },
    {
      "label": "Button pills for sizes",
      "html": "<div data-scope=\"product:p2\" data-island=\"VariantSelector\" data-props='{\"product\":{\"variants\":[{\"id\":\"v1\",\"title\":\"S\",\"price\":\"$29\",\"available\":true,\"options\":{\"Size\":\"S\"}},{\"id\":\"v2\",\"title\":\"M\",\"price\":\"$29\",\"available\":true,\"options\":{\"Size\":\"M\"}},{\"id\":\"v3\",\"title\":\"L\",\"price\":\"$29\",\"available\":false,\"options\":{\"Size\":\"L\"}}],\"options\":[{\"name\":\"Size\",\"values\":[\"S\",\"M\",\"L\"]}]},\"render\":\"buttons\"}'></div>"
    },
    {
      "label": "Dropdown selector",
      "html": "<div data-scope=\"product:p3\" data-island=\"VariantSelector\" data-props='{\"product\":{\"variants\":[{\"id\":\"v1\",\"title\":\"Default\",\"price\":\"$99\",\"available\":true,\"options\":{\"Style\":\"Classic\"}},{\"id\":\"v2\",\"title\":\"Modern\",\"price\":\"$109\",\"available\":true,\"options\":{\"Style\":\"Modern\"}}],\"options\":[{\"name\":\"Style\",\"values\":[\"Classic\",\"Modern\"]}]},\"render\":\"dropdown\"}'></div>"
    }
  ],
  "props": {
    "product": {
      "type": "object",
      "required": true,
      "shape": {
        "variants": "array<{id: string, title: string, price: string, compareAtPrice: ?string, available: boolean, image: ?string, images: ?array<{}>, options: object}>",
        "options": "array<{name: string, values: array<string>}>"
      }
    },
    "render": {
      "type": "enum",
      "required": false,
      "values": [
        "dropdown",
        "swatches",
        "buttons"
      ],
      "default": "buttons"
    },
    "defaultVariant": {
      "type": "string",
      "required": false
    }
  },
  "variants": null,
  "css_vars": [
    "--lx-accent-color",
    "--lx-border-color",
    "--lx-text-color"
  ],
  "parts": [
    "dropdown",
    "option-btn",
    "option-group",
    "option-label",
    "option-values",
    "root",
    "swatch"
  ],
  "example": "<div data-island=\"VariantSelector\" data-props='{\"product\":{\"variants\":[],\"options\":[]}}'></div>"
}
