{
  "id": "product-gallery",
  "html": "<section class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24\"><div class=\"grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-4\"><div class=\"col-span-2 row-span-2 aspect-[3/4] rounded-lg overflow-hidden\"><img src=\"{{IMAGE_URL}}\" alt=\"{{PRODUCT_TITLE}} — Main\" class=\"w-full h-full object-cover\" /></div><div class=\"aspect-square rounded-lg overflow-hidden\" style=\"background-color: var(--lx-surface-alt)\"><img src=\"{{IMAGE_URL_2}}\" alt=\"{{PRODUCT_TITLE}} — Detail\" class=\"w-full h-full object-cover\" /></div><div class=\"aspect-square rounded-lg overflow-hidden\" style=\"background-color: var(--lx-surface-alt)\"><img src=\"{{IMAGE_URL_3}}\" alt=\"{{PRODUCT_TITLE}} — Lifestyle\" class=\"w-full h-full object-cover\" /></div></div><div class=\"mt-4 flex justify-center\"><div data-island=\"ProductGallery\" data-props='{\"productId\":\"{{PRODUCT_ID}}\",\"layout\":\"horizontal\",\"enableZoom\":true,\"maxImages\":6,\"showThumbnails\":false}'></div></div></section>",
