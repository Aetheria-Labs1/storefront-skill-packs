{
  "name": "MediaCarousel",
  "category": "unknown",
  "usage_hint": "Standalone media carousel for image/video cycling inside custom HTML cards or hero sections. Supports fade/slide/zoom/kenBurns transitions, autoplay, arrows, dots, and touch swipe.",
  "when_to_use": "Use inside custom HTML product cards, hero banners, or anywhere you need image cycling as a composable primitive. Fully CSS-customizable via --lx-carousel-* properties.",
  "when_not_to_use": "Not for full product galleries with thumbnails (use ProductGallery). Not for horizontal product scrolling (use data-behavior=\"horizontal-scroll\" or ProductCarousel).",
  "defaultHydrate": "visible",
  "combine_with": [
    "QuickAdd (for product cards)",
    "VariantSelector (to change images on variant select)"
  ],
  "anti_patterns": [
    "Using with single image (no carousel needed, use plain <img>)",
    "Enabling swipeable inside a horizontal-scroll container (gesture conflict)",
    "Setting autoplay with very short interval (<2000ms) \u2014 disorienting"
  ],
  "examples": [
    {
      "label": "Basic fade carousel with dots",
      "html": "<div data-island=\"MediaCarousel\" data-props='{\"media\":[{\"src\":\"https://via.placeholder.com/400x500\",\"alt\":\"Image 1\"},{\"src\":\"https://via.placeholder.com/400x500\",\"alt\":\"Image 2\"}],\"transition\":\"fade\",\"showDots\":true,\"aspect\":\"3:4\"}'></div>"
    },
    {
      "label": "Hover-advance carousel (for product cards)",
      "html": "<div data-island=\"MediaCarousel\" data-props='{\"media\":[{\"src\":\"https://via.placeholder.com/400\",\"alt\":\"Front\"},{\"src\":\"https://via.placeholder.com/400\",\"alt\":\"Back\"}],\"hoverAdvance\":true,\"showDots\":true,\"aspect\":\"1:1\"}'></div>"
    },
    {
      "label": "Autoplay with arrows",
      "html": "<div data-island=\"MediaCarousel\" data-props='{\"media\":[{\"src\":\"https://via.placeholder.com/800x400\",\"alt\":\"Slide 1\"},{\"src\":\"https://via.placeholder.com/800x400\",\"alt\":\"Slide 2\"},{\"src\":\"https://via.placeholder.com/800x400\",\"alt\":\"Slide 3\"}],\"autoplay\":true,\"interval\":4000,\"showArrows\":true,\"aspect\":\"16:9\"}'></div>"
    }
  ],
  "props": {
    "media": {
      "type": "array",
      "required": true,
      "shape": {
        "src": "string",
        "alt": "?string",
        "poster": "?string"
      }
    },
    "transition": {
      "type": "enum",
      "required": false,
      "values": [
        "none",
        "fade",
        "slide",
        "zoom",
        "kenBurns"
      ],
      "default": "fade"
    },
    "autoplay": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "interval": {
      "type": "number",
      "required": false,
      "default": "4000"
    },
    "pauseOnHover": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "hoverAdvance": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "showArrows": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "showDots": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "aspect": {
      "type": "string",
      "required": false,
      "default": "1:1"
    },
    "fit": {
      "type": "enum",
      "required": false,
      "values": [
        "cover",
        "contain"
      ],
      "default": "cover"
    },
    "loop": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "swipeable": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "animate": {
      "type": "boolean",
      "required": false,
      "default": "true"
    }
  },
  "variants": null,
  "css_vars": [
    "--lx-carousel-",
    "--lx-carousel-arrow-bg",
    "--lx-carousel-arrow-color",
    "--lx-carousel-dot-active",
    "--lx-carousel-dot-color"
  ],
  "parts": [
    "arrow-next",
    "arrow-prev",
    "dots",
    "root",
    "scroll-container",
    "slide"
  ],
  "example": "<div data-island=\"MediaCarousel\" data-props='{\"media\":[{\"src\":\"example-src\"}]}'></div>"
}
