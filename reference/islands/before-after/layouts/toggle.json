{
  "id": "before-after-toggle",
  "html": "<section class=\"max-w-3xl mx-auto px-4 py-12 md:py-16 lg:py-20\"><div class=\"space-y-6 text-center\"><h2 class=\"text-2xl md:text-3xl font-bold\" style=\"font-family: var(--lx-font-heading); color: var(--lx-text-color)\">{{HEADING}}</h2><p style=\"color: var(--lx-text-muted)\">{{SUBHEADING}}</p><div class=\"max-w-md mx-auto\"><div data-island=\"BeforeAfter\" data-props='{\"before\":{\"src\":\"{{BEFORE_IMAGE}}\",\"label\":\"{{BEFORE_LABEL}}\"},\"after\":{\"src\":\"{{AFTER_IMAGE}}\",\"label\":\"{{AFTER_LABEL}}\"},\"orientation\":\"vertical\",\"showLabels\":true}'></div></div><div class=\"flex items-center justify-center gap-3 pt-2\"><span class=\"text-sm font-medium\" style=\"color: var(--lx-text-muted)\">Tap to toggle view</span></div></div></section>",
  "css": "",
  "js": ""
}
