{
  "id": "image-zoom-magnifier",
  "html": "<section class=\"max-w-3xl mx-auto px-4 py-12 md:py-16 lg:py-20\"><div class=\"space-y-6\"><h2 class=\"text-2xl md:text-3xl font-bold text-center\" style=\"font-family: var(--lx-font-heading); color: var(--lx-text-color)\">{{HEADING}}</h2><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-6 items-start\"><div class=\"aspect-square rounded-lg overflow-hidden\" style=\"border: 1px solid var(--lx-border-color)\"><div data-island=\"ImageZoom\" data-props='{\"src\":\"{{IMAGE_SRC}}\",\"alt\":\"{{IMAGE_ALT}}\",\"zoomLevel\":3,\"trigger\":\"hover\"}'></div></div><div class=\"aspect-square rounded-lg flex items-center justify-center\" style=\"background: var(--lx-surface-alt); border: 1px solid var(--lx-border-color)\"><span class=\"text-sm\" style=\"color: var(--lx-text-muted)\">Magnified view appears here</span></div></div><p class=\"text-center text-sm\" style=\"color: var(--lx-text-muted)\">Hover over the image to see magnified details in the panel</p></div></section>",
  "css": "",
  "js": ""
}
