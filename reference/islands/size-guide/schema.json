{
  "name": "SizeGuide",
  "category": "engagement",
  "usage_hint": "Modal size chart with metric/imperial toggle. Trigger button opens overlay table with size measurements.",
  "when_to_use": "On apparel, footwear, or gear product pages. Shows measurement table (chest, waist, length, etc.) in modal. Optional unit toggle (cm/inches) and measurement tip. Trigger is inline link/button.",
  "when_not_to_use": "For products without size variations. When sizes are standard (S/M/L with no measurement chart). For size recommender tools (this is static chart, not AI fitting).",
  "defaultHydrate": "immediate",
  "combine_with": [
    "VariantSelector (size dropdown)",
    "BuyBox",
    "ProductDescription"
  ],
  "anti_patterns": [
    "Providing incomplete size data (missing sizes or measurements breaks trust)",
    "Using generic size chart for products with different fits (oversized vs slim \u2014 needs separate charts)",
    "Not including measurement tip (customers don't know how to measure themselves)"
  ],
  "examples": [
    {
      "label": "Apparel size guide with unit toggle",
      "html": "<div data-island=\"SizeGuide\" data-props='{\"title\":\"Size Guide\",\"headers\":[\"Size\",\"Chest\",\"Waist\",\"Length\"],\"rows\":[{\"size\":\"Small\",\"chest\":\"34-36\\\"\",\"waist\":\"28-30\\\"\",\"length\":\"28\\\"\"},{\"size\":\"Medium\",\"chest\":\"38-40\\\"\",\"waist\":\"32-34\\\"\",\"length\":\"29\\\"\"},{\"size\":\"Large\",\"chest\":\"42-44\\\"\",\"waist\":\"36-38\\\"\",\"length\":\"30\\\"\"}],\"units\":{\"metric\":\"cm\",\"imperial\":\"inches\"},\"tip\":\"Measure around the fullest part of your chest\"}'></div>"
    },
    {
      "label": "Footwear size chart",
      "html": "<div data-island=\"SizeGuide\" data-props='{\"title\":\"Shoe Size Chart\",\"headers\":[\"US Size\",\"UK Size\",\"EU Size\",\"Foot Length\"],\"rows\":[{\"size\":\"8\",\"uk size\":\"7\",\"eu size\":\"41\",\"foot length\":\"26cm\"},{\"size\":\"9\",\"uk size\":\"8\",\"eu size\":\"42\",\"foot length\":\"27cm\"}],\"tip\":\"Measure from heel to longest toe\"}'></div>"
    },
    {
      "label": "Simple size guide without units",
      "html": "<div data-island=\"SizeGuide\" data-props='{\"title\":\"Fit Guide\",\"headers\":[\"Size\",\"Fits Height\",\"Fits Weight\"],\"rows\":[{\"size\":\"S\",\"fits height\":\"5'4\\\"-5'7\\\"\",\"fits weight\":\"120-140 lbs\"},{\"size\":\"M\",\"fits height\":\"5'7\\\"-5'10\\\"\",\"fits weight\":\"140-165 lbs\"}]}'></div>"
    }
  ],
  "props": {
    "title": {
      "type": "string",
      "required": false,
      "default": "Size Guide"
    },
    "headers": {
      "type": "array",
      "required": true
    },
    "rows": {
      "type": "array",
      "required": true,
      "shape": {
        "size": "string"
      }
    },
    "units": {
      "type": "object",
      "required": false,
      "shape": {
        "metric": "string",
        "imperial": "string"
      }
    },
    "tip": {
      "type": "string",
      "required": false
    }
  },
  "variants": null,
  "css_vars": [
    "--lx-accent-color",
    "--lx-text-color"
  ],
  "parts": [
    "body-row",
    "cell",
    "header-row",
    "modal",
    "root",
    "table",
    "trigger"
  ],
  "example": "<div data-island=\"SizeGuide\" data-props='{\"headers\":[],\"rows\":[{\"size\":\"example-size\"}]}'></div>"
}
