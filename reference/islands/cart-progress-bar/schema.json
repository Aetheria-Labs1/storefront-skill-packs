{
  "name": "CartProgressBar",
  "category": "commerce",
  "usage_hint": "Shows progress toward free shipping or tiered rewards. Subscribes to shared cart state.",
  "when_to_use": "Inside DrawerShell above CartLines to incentivize adding more items. Shows a visual bar and templated message.",
  "when_not_to_use": "If the store does not offer free shipping thresholds or tiered incentives.",
  "defaultHydrate": "idle",
  "combine_with": [
    "DrawerShell",
    "CartLines",
    "CartSummary"
  ],
  "anti_patterns": [],
  "examples": [],
  "props": {
    "threshold": {
      "type": "number",
      "required": false
    },
    "message": {
      "type": "string",
      "required": false,
      "default": "{remaining} away from free shipping!"
    },
    "completedMessage": {
      "type": "string",
      "required": false,
      "default": "Free shipping unlocked!"
    },
    "tiers": {
      "type": "array",
      "required": false,
      "shape": {
        "threshold": "number",
        "label": "string"
      }
    },
    "currency": {
      "type": "string",
      "required": false
    }
  },
  "variants": null,
  "css_vars": [
    "--lx-accent-color"
  ],
  "parts": [
    "bar",
    "message",
    "root",
    "track"
  ],
  "example": "<div data-island=\"CartProgressBar\" data-props='{}'></div>"
}
