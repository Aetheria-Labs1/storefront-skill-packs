{
  "name": "InventoryIndicator",
  "category": "commerce",
  "usage_hint": "Low stock badge/bar/text that shows inventory urgency. Listens for variant:changed events and emits inventory:updated.",
  "when_to_use": "On product pages to create urgency when stock is low. Shows \"Only X left\" or \"Out of stock\". Three variants: badge (pill), bar (progress), text (inline). Auto-hides when stock is above threshold.",
  "when_not_to_use": "For products where inventory urgency doesn't drive sales. When inventory data isn't available. For pre-order or made-to-order products (misleading).",
  "defaultHydrate": "immediate",
  "combine_with": [
    "BuyBox",
    "VariantSelector",
    "OptionResolver",
    "ProductPrice"
  ],
  "anti_patterns": [
    "Setting lowStockThreshold too high (everything shows as \"low\" \u2014 loses urgency impact)",
    "Showing exact count when inventory is high (exposes supply chain data unnecessarily)",
    "Using variant=\"bar\" without enough horizontal space (bars need width to be readable)"
  ],
  "examples": [
    {
      "label": "Badge variant with exact count",
      "html": "<div data-island=\"InventoryIndicator\" data-props='{\"variantId\":\"gid://shopify/ProductVariant/123\",\"quantity\":4,\"lowStockThreshold\":10,\"urgentThreshold\":3,\"showExactCount\":true,\"variant\":\"badge\"}'></div>"
    },
    {
      "label": "Bar variant that listens for variant changes",
      "html": "<div data-island=\"InventoryIndicator\" data-props='{\"quantity\":8,\"lowStockThreshold\":15,\"urgentThreshold\":5,\"listenForEvents\":true,\"variant\":\"bar\",\"showExactCount\":true}'></div>"
    },
    {
      "label": "Text variant without exact count",
      "html": "<div data-island=\"InventoryIndicator\" data-props='{\"variantId\":\"gid://shopify/ProductVariant/789\",\"quantity\":2,\"lowStockThreshold\":5,\"urgentThreshold\":3,\"showExactCount\":false,\"variant\":\"text\"}'></div>"
    }
  ],
  "props": {
    "variantId": {
      "type": "string",
      "required": false
    },
    "quantity": {
      "type": "number",
      "required": false
    },
    "lowStockThreshold": {
      "type": "number",
      "required": false,
      "default": "5"
    },
    "urgentThreshold": {
      "type": "number",
      "required": false,
      "default": "3"
    },
    "showExactCount": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "listenForEvents": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "variant": {
      "type": "enum",
      "required": false,
      "values": [
        "badge",
        "bar",
        "text"
      ],
      "default": "badge"
    }
  },
  "variants": [
    "badge",
    "bar",
    "text"
  ],
  "css_vars": [],
  "parts": [
    "bar-fill",
    "bar-track",
    "dot",
    "message",
    "root"
  ],
  "example": "<div data-island=\"InventoryIndicator\" data-props='{}'></div>"
}
