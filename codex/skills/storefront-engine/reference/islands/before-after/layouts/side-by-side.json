{
  "id": "before-after-side-by-side",
  "html": "<section class=\"max-w-3xl mx-auto px-4 py-12 md:py-16 lg:py-20\"><div class=\"space-y-6\"><h2 class=\"text-2xl md:text-3xl font-bold text-center\" style=\"font-family: var(--lx-font-heading); color: var(--lx-text-color)\">{{HEADING}}</h2><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div class=\"space-y-3\"><span class=\"inline-block px-3 py-1 text-sm font-medium rounded-full\" style=\"background-color: var(--lx-surface-alt); color: var(--lx-text-muted)\">{{BEFORE_LABEL}}</span><div data-island=\"BeforeAfter\" data-props='{\"before\":{\"src\":\"{{BEFORE_IMAGE}}\",\"label\":\"{{BEFORE_LABEL}}\"},\"after\":{\"src\":\"{{AFTER_IMAGE}}\",\"label\":\"{{AFTER_LABEL}}\"},\"orientation\":\"horizontal\",\"showLabels\":true}'></div></div><div class=\"space-y-3\"><span class=\"inline-block px-3 py-1 text-sm font-medium rounded-full\" style=\"background-color: var(--lx-surface-alt); color: var(--lx-text-muted)\">{{AFTER_LABEL}}</span><div class=\"aspect-[4/3] rounded-lg overflow-hidden\" style=\"border: 1px solid var(--lx-border-color)\"><img src=\"{{AFTER_IMAGE}}\" alt=\"{{AFTER_LABEL}}\" class=\"w-full h-full object-cover\" /></div></div></div></div></section>",
  "css": "",
  "js": ""
}
