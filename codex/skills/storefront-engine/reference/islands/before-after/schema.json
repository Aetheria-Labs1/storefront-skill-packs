{
  "name": "BeforeAfter",
  "category": "content",
  "usage_hint": "Before/after image comparison slider with draggable divider. Supports horizontal and vertical orientation.",
  "when_to_use": "For product transformations (skincare, makeup, home improvement, photo editing tools). User drags divider to reveal before/after images. Supports optional labels.",
  "when_not_to_use": "For simple image galleries use ProductImage carousel. When images don't align perfectly (different crops/angles look broken). For video comparisons use side-by-side videos instead.",
  "combine_with": [
    "ProductImage",
    "ProductDescription",
    "Testimonials",
    "Hero sections"
  ],
  "anti_patterns": [
    "Using images with different aspect ratios (causes misalignment)",
    "Setting initialPosition to extreme (0 or 100) \u2014 users don't realize it's interactive",
    "Using low-resolution images (pixelation ruins credibility of before/after claim)"
  ],
  "examples": [
    {
      "label": "Horizontal skincare before/after",
      "html": "<div data-island=\"BeforeAfter\" data-props='{\"before\":{\"src\":\"/images/before.jpg\",\"label\":\"Before\"},\"after\":{\"src\":\"/images/after.jpg\",\"label\":\"After\"},\"orientation\":\"horizontal\",\"initialPosition\":50}'></div>"
    },
    {
      "label": "Vertical photo edit comparison",
      "html": "<div data-island=\"BeforeAfter\" data-props='{\"before\":{\"src\":\"/images/original.jpg\",\"label\":\"Original\"},\"after\":{\"src\":\"/images/edited.jpg\",\"label\":\"Enhanced\"},\"orientation\":\"vertical\",\"initialPosition\":50}'></div>"
    },
    {
      "label": "Home improvement without labels",
      "html": "<div data-island=\"BeforeAfter\" data-props='{\"before\":{\"src\":\"/images/old-room.jpg\"},\"after\":{\"src\":\"/images/renovated.jpg\"},\"orientation\":\"horizontal\",\"initialPosition\":60}'></div>"
    }
  ],
  "props": {
    "before": {
      "type": "object",
      "required": true,
      "shape": {
        "src": "string",
        "label": "?string"
      }
    },
    "after": {
      "type": "object",
      "required": true,
      "shape": {
        "src": "string",
        "label": "?string"
      }
    },
    "orientation": {
      "type": "enum",
      "required": false,
      "values": [
        "horizontal",
        "vertical"
      ],
      "default": "horizontal"
    },
    "initialPosition": {
      "type": "number",
      "required": false,
      "default": "50"
    }
  },
  "variants": null,
  "css_vars": [
    "--lx-accent-color"
  ],
  "parts": [
    "after-image",
    "before-image",
    "handle",
    "root",
    "slider"
  ],
  "example": "<div data-island=\"BeforeAfter\" data-props='{\"before\":{\"src\":\"example-src\"},\"after\":{\"src\":\"example-src\"}}'></div>"
}
