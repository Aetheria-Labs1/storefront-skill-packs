{
  "name": "VideoPlayer",
  "category": "content",
  "usage_hint": "Responsive video player with controls, autoplay, loop. Supports direct video files and YouTube/Vimeo embeds.",
  "when_to_use": "For product demos, how-to videos, brand stories. Auto-detects YouTube/Vimeo URLs and renders iframe embed. For direct videos shows custom controls (play/pause, progress, mute). Poster image for thumbnail.",
  "when_not_to_use": "For background ambient video use HTML5 video tag directly. For short animated clips consider GIF or CSS animations. When video isn't core to conversion.",
  "combine_with": [
    "ProductImage",
    "Hero sections",
    "ProductDescription"
  ],
  "anti_patterns": [
    "Autoplaying unmuted video (violates accessibility and most browsers block it)",
    "Using large uncompressed video files (>5MB \u2014 slows page load)",
    "Not providing poster image (shows blank frame until video loads)"
  ],
  "examples": [
    {
      "label": "Direct video with poster",
      "html": "<div data-island=\"VideoPlayer\" data-props='{\"src\":\"/videos/product-demo.mp4\",\"poster\":\"/images/video-poster.jpg\",\"autoplay\":false,\"muted\":false,\"loop\":false,\"aspectRatio\":\"16/9\"}'></div>"
    },
    {
      "label": "YouTube embed with autoplay",
      "html": "<div data-island=\"VideoPlayer\" data-props='{\"src\":\"https://www.youtube.com/watch?v=dQw4w9WgXcQ\",\"poster\":\"/images/yt-thumb.jpg\",\"autoplay\":true,\"aspectRatio\":\"16/9\"}'></div>"
    },
    {
      "label": "Vimeo embed looping",
      "html": "<div data-island=\"VideoPlayer\" data-props='{\"src\":\"https://vimeo.com/123456789\",\"autoplay\":true,\"muted\":true,\"loop\":true,\"aspectRatio\":\"16/9\"}'></div>"
    }
  ],
  "props": {
    "src": {
      "type": "string",
      "required": true
    },
    "poster": {
      "type": "string",
      "required": false
    },
    "autoplay": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "muted": {
      "type": "boolean",
      "required": false
    },
    "loop": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "aspectRatio": {
      "type": "string",
      "required": false,
      "default": "16/9"
    }
  },
  "variants": null,
  "css_vars": [
    "--lx-accent-color"
  ],
  "parts": [
    "control-mute",
    "control-play",
    "controls",
    "play-btn",
    "poster-overlay",
    "progress-fill",
    "progress-track",
    "root",
    "video"
  ],
  "example": "<div data-island=\"VideoPlayer\" data-props='{\"src\":\"example-src\"}'></div>"
}
