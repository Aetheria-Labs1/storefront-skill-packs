{
  "name": "CartLines",
  "category": "commerce",
  "usage_hint": "Renders cart line items with quantity controls and remove buttons. Subscribes to shared cart state.",
  "when_to_use": "Inside DrawerShell as the main cart items list. Shows each line with image, title, variant, price, and quantity +/- controls.",
  "when_not_to_use": "Outside a cart context. If you need a static product list, use ProductCarousel instead.",
  "combine_with": [
    "DrawerShell",
    "CartSummary",
    "CartCheckoutButton",
    "CartProgressBar"
  ],
  "anti_patterns": [],
  "examples": [],
  "props": {
    "layout": {
      "type": "enum",
      "required": false,
      "values": [
        "compact",
        "full"
      ],
      "default": "compact"
    },
    "showQuantity": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "showRemove": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "showImage": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "emptyMessage": {
      "type": "string",
      "required": false,
      "default": "Your cart is empty"
    },
    "emptyCtaText": {
      "type": "string",
      "required": false,
      "default": "Continue Shopping"
    },
    "emptyCtaUrl": {
      "type": "string",
      "required": false,
      "default": "/"
    }
  },
  "variants": [
    "compact",
    "full"
  ],
  "css_vars": [
    "--lx-accent-color",
    "--lx-text-color"
  ],
  "parts": [
    "empty",
    "empty-cta",
    "empty-message",
    "item",
    "item-image",
    "item-info",
    "item-price",
    "item-title",
    "item-variant",
    "qty-btn",
    "qty-controls",
    "qty-value",
    "remove-btn",
    "root"
  ],
  "example": "<div data-island=\"CartLines\" data-props='{}'></div>"
}
