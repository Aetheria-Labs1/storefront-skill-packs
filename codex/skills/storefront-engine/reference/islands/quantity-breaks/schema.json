{
  "name": "QuantityBreaks",
  "category": "commerce",
  "usage_hint": "Tiered bulk pricing selector with radio buttons and add-to-cart action. Buy more, save more UI pattern.",
  "when_to_use": "For products with volume discounts (wholesale, bulk bundles). Each tier shows quantity, price, per-unit cost, and optional savings label. Clicking \"Add to Cart\" adds the selected tier quantity in one action.",
  "when_not_to_use": "For subscription pricing use SubscriptionToggle. For simple quantity selectors use BuyBox. When you want separate quantity input + add button (this island combines them).",
  "combine_with": [
    "ProductImage",
    "ProductPrice",
    "InventoryIndicator"
  ],
  "anti_patterns": [
    "Using with BuyBox on the same page (they both add to cart \u2014 causes duplicate buttons)",
    "Setting tier quantities that exceed available inventory without checking stock first",
    "Listing tiers in non-ascending order (confusing \u2014 always show smallest to largest quantity)"
  ],
  "examples": [
    {
      "label": "Three-tier bulk pricing",
      "html": "<div data-island=\"QuantityBreaks\" data-props='{\"variantId\":\"gid://shopify/ProductVariant/123\",\"tiers\":[{\"quantity\":1,\"price\":\"$10.00\",\"perUnit\":\"$10.00\"},{\"quantity\":3,\"price\":\"$27.00\",\"perUnit\":\"$9.00\",\"savings\":\"$3.00\",\"label\":\"Save 10%\"},{\"quantity\":5,\"price\":\"$40.00\",\"perUnit\":\"$8.00\",\"savings\":\"$10.00\",\"label\":\"Best Value\"}],\"currency\":\"USD\"}'></div>"
    },
    {
      "label": "Simple two-tier discount",
      "html": "<div data-island=\"QuantityBreaks\" data-props='{\"variantId\":\"gid://shopify/ProductVariant/456\",\"tiers\":[{\"quantity\":1,\"price\":\"$25.00\",\"perUnit\":\"$25.00\"},{\"quantity\":2,\"price\":\"$45.00\",\"perUnit\":\"$22.50\",\"savings\":\"$5.00\",\"label\":\"Popular\"}]}'></div>"
    },
    {
      "label": "Wholesale tiers with labels",
      "html": "<div data-island=\"QuantityBreaks\" data-props='{\"variantId\":\"gid://shopify/ProductVariant/789\",\"tiers\":[{\"quantity\":12,\"price\":\"$120.00\",\"perUnit\":\"$10.00\",\"label\":\"Retail Pack\"},{\"quantity\":24,\"price\":\"$216.00\",\"perUnit\":\"$9.00\",\"savings\":\"$24.00\",\"label\":\"Wholesale\"},{\"quantity\":48,\"price\":\"$384.00\",\"perUnit\":\"$8.00\",\"savings\":\"$96.00\",\"label\":\"Distributor\"}]}'></div>"
    }
  ],
  "props": {
    "tiers": {
      "type": "array",
      "required": true,
      "shape": {
        "quantity": "number",
        "price": "string",
        "perUnit": "string",
        "savings": "?string",
        "label": "?string"
      }
    },
    "variantId": {
      "type": "string",
      "required": true
    },
    "currency": {
      "type": "string",
      "required": false
    }
  },
  "variants": null,
  "css_vars": [
    "--lx-accent-color",
    "--lx-text-color"
  ],
  "parts": [
    "root",
    "tier",
    "tier-badge",
    "tier-discount",
    "tier-price",
    "tier-qty"
  ],
  "example": "<div data-island=\"QuantityBreaks\" data-props='{\"tiers\":[{\"quantity\":0,\"price\":\"example-price\",\"perUnit\":\"example-perUnit\"}],\"variantId\":\"example-variantId\"}'></div>"
}
