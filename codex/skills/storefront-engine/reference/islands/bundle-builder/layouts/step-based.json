{
  "id": "bundle-step-based",
  "html": "<section class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16 lg:py-20\" style=\"background-color: var(--lx-surface-alt)\"><div class=\"text-center mb-8 md:mb-12\"><h2 class=\"text-2xl md:text-3xl lg:text-4xl font-bold\" style=\"font-family: var(--lx-font-heading); color: var(--lx-text-color)\">Build Your Bundle</h2><p class=\"mt-3 text-lg max-w-2xl mx-auto\" style=\"color: var(--lx-text-muted)\">Choose your favorites and save more with every item added</p></div><div class=\"flex items-center justify-center gap-2 mb-8\"><span class=\"inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold text-white\" style=\"background: var(--lx-accent-color)\">1</span><span class=\"text-sm font-medium\" style=\"color: var(--lx-accent-color)\">Choose</span><div class=\"w-12 h-px\" style=\"background: var(--lx-border-color)\"></div><span class=\"inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold\" style=\"background: var(--lx-border-color); color: var(--lx-text-muted)\">2</span><span class=\"text-sm\" style=\"color: var(--lx-text-muted)\">Review</span><div class=\"w-12 h-px\" style=\"background: var(--lx-border-color)\"></div><span class=\"inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold\" style=\"background: var(--lx-border-color); color: var(--lx-text-muted)\">3</span><span class=\"text-sm\" style=\"color: var(--lx-text-muted)\">Checkout</span></div><div class=\"rounded-lg border p-4 mb-6 text-center text-sm\" style=\"border-color: var(--lx-accent-color); background: linear-gradient(135deg, #FFF7ED, #FFEDD5); color: var(--lx-text-color)\"><strong>Discount Tiers:</strong> Buy 2 save 10% | Buy 3 save 15% | Buy 4+ save 20%</div><div data-island=\"BundleBuilder\" data-props='{\"variant\":\"stacked\",\"productIds\":{{PRODUCT_IDS}},\"discountTiers\":{{DISCOUNT_TIERS}},\"ctaText\":\"{{CTA_TEXT}}\",\"showProgress\":true,\"maxItems\":6}'></div></section>",
  "css": "",
  "js": ""
}
