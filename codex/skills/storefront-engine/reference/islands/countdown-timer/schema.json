{
  "name": "CountdownTimer",
  "category": "content",
  "usage_hint": "Live countdown timer for sales, launches, or deadlines. Updates every second. Three styles: simple (boxes + separators), flip (animated), circular (progress rings).",
  "when_to_use": "For flash sales, product launches, limited offers, event countdowns. Shows days/hours/minutes/seconds. Auto-hides when expired and shows expiredMessage. Supports custom CSS variables for styling.",
  "when_not_to_use": "For static \"Sale ends soon\" text use plain HTML. When deadline isn't firm (countdown creates urgency, broken promises hurt trust). For long durations (>30 days \u2014 use date instead).",
  "combine_with": [
    "Hero sections",
    "ProductPrice",
    "AnnouncementBar",
    "BuyBox"
  ],
  "anti_patterns": [
    "Setting endDate in the past (shows \"Time's up!\" immediately \u2014 test with future dates)",
    "Using countdown for evergreen \"fake urgency\" (resets on page load \u2014 customers notice and distrust)",
    "Placing multiple CountdownTimer instances for same deadline (redundant + confusing)"
  ],
  "examples": [
    {
      "label": "Simple style flash sale",
      "html": "<div data-island=\"CountdownTimer\" data-props='{\"endDate\":\"2026-12-31T23:59:59Z\",\"labels\":{\"days\":\"Days\",\"hours\":\"Hours\",\"minutes\":\"Min\",\"seconds\":\"Sec\"},\"expiredMessage\":\"Sale ended\",\"style\":\"simple\"}'></div>"
    },
    {
      "label": "Circular progress style",
      "html": "<div data-island=\"CountdownTimer\" data-props='{\"endDate\":\"2026-07-15T18:00:00Z\",\"labels\":{\"days\":\"D\",\"hours\":\"H\",\"minutes\":\"M\",\"seconds\":\"S\"},\"style\":\"circular\"}'></div>"
    },
    {
      "label": "Flip style with custom message",
      "html": "<div data-island=\"CountdownTimer\" data-props='{\"endDate\":\"2026-08-01T00:00:00Z\",\"expiredMessage\":\"Product launched! Shop now\",\"style\":\"flip\"}'></div>"
    }
  ],
  "props": {
    "endDate": {
      "type": "string",
      "required": true
    },
    "labels": {
      "type": "object",
      "required": false,
      "shape": {
        "days": "?string",
        "hours": "?string",
        "minutes": "?string",
        "seconds": "?string"
      },
      "default": "{}"
    },
    "expiredMessage": {
      "type": "string",
      "required": false,
      "default": "Time's up!"
    },
    "style": {
      "type": "enum",
      "required": false,
      "values": [
        "flip",
        "simple",
        "circular"
      ],
      "default": "simple"
    }
  },
  "variants": [
    "flip",
    "simple",
    "circular"
  ],
  "css_vars": [
    "--lx-accent-color",
    "--lx-countdown-bg",
    "--lx-countdown-border",
    "--lx-countdown-font-size",
    "--lx-countdown-gap",
    "--lx-countdown-label-color",
    "--lx-countdown-label-size",
    "--lx-countdown-radius",
    "--lx-countdown-separator-color",
    "--lx-countdown-separator-size",
    "--lx-countdown-shadow",
    "--lx-countdown-size"
  ],
  "parts": [
    "box",
    "digit",
    "label",
    "ring",
    "root",
    "separator",
    "unit"
  ],
  "example": "<div data-island=\"CountdownTimer\" data-props='{\"endDate\":\"example-endDate\"}'></div>"
}
