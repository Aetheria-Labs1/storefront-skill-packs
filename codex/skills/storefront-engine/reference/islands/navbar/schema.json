{
  "name": "Navbar",
  "category": "navigation",
  "usage_hint": "Site-wide top navigation bar with logo, links, cart, and mobile menu.",
  "when_to_use": "When you need persistent navigation across all pages. Supports both hydration mode (custom HTML with data-lx-nav tags) and legacy mode (React-rendered with props). Cart badge auto-syncs with cart state.",
  "when_not_to_use": "For announcement-only headers use AnnouncementBar. For combined announcement + nav use SiteHeader. For page-specific navigation use MobileMenu (standalone mobile sheet).",
  "combine_with": [
    "CartDrawer",
    "Footer",
    "AnnouncementBar",
    "BackToTop"
  ],
  "anti_patterns": [
    "Using both SiteHeader and Navbar on the same page \u2014 SiteHeader already includes Navbar functionality",
    "Placing Navbar inside a section wrapper \u2014 it should be a direct page child for sticky positioning to work",
    "Hard-coding cart count instead of omitting it (the island subscribes to real cart state automatically)"
  ],
  "examples": [
    {
      "label": "Hydration mode with custom HTML",
      "html": "<div data-island=\"Navbar\" data-props='{\"sticky\":true,\"cartMode\":\"drawer\"}'><nav data-lx-nav=\"root\"><a href=\"/\"><img src=\"/logo.svg\" alt=\"Logo\"/></a><button data-lx-nav=\"cart-trigger\"><svg>...</svg><span data-lx-nav=\"cart-count\"></span></button><button data-lx-nav=\"mobile-trigger\">Menu</button><div data-lx-nav=\"mobile-panel\">...</div></nav></div>"
    },
    {
      "label": "Legacy mode with transparent sticky nav",
      "html": "<div data-island=\"Navbar\" data-props='{\"logo\":{\"src\":\"/logo.svg\",\"alt\":\"Store\"},\"links\":[{\"label\":\"Shop\",\"url\":\"/collections\"},{\"label\":\"About\",\"url\":\"/pages/about\"}],\"transparent\":true,\"sticky\":true,\"style\":{\"accentColor\":\"#5055aa\"}}'></div>"
    },
    {
      "label": "Legacy mode with dropdown menu and CTA",
      "html": "<div data-island=\"Navbar\" data-props='{\"logo\":{\"src\":\"/logo.svg\"},\"links\":[{\"label\":\"Products\",\"url\":\"#\",\"children\":[{\"label\":\"New\",\"url\":\"/new\"},{\"label\":\"Sale\",\"url\":\"/sale\"}]},{\"label\":\"Contact\",\"url\":\"/contact\"}],\"cta\":{\"label\":\"Sign Up\",\"url\":\"/signup\"}}'></div>"
    }
  ],
  "props": {
    "sticky": {
      "type": "boolean",
      "required": false
    },
    "cartMode": {
      "type": "enum",
      "required": false,
      "values": [
        "drawer",
        "link"
      ]
    },
    "cartUrl": {
      "type": "string",
      "required": false
    },
    "transparent": {
      "type": "boolean",
      "required": false
    },
    "offsetTop": {
      "type": "string",
      "required": false
    },
    "hideCart": {
      "type": "boolean",
      "required": false
    },
    "logo": {
      "type": "object",
      "required": true,
      "shape": {
        "src": "string",
        "alt": "?string",
        "url": "?string"
      }
    },
    "links": {
      "type": "array",
      "required": true,
      "shape": {
        "label": "string",
        "url": "string",
        "children": "?array<{label: string, url: string, children: ?array<{}>}>"
      }
    },
    "cartCount": {
      "type": "number",
      "required": false
    },
    "style": {
      "type": "object",
      "required": false,
      "shape": {
        "bgColor": "?string",
        "textColor": "?string",
        "accentColor": "?string",
        "logoHeight": "?string",
        "height": "?string",
        "borderBottom": "?string",
        "fontFamily": "?string",
        "fontSize": "?string",
        "fontWeight": "?string",
        "padding": "?string",
        "maxWidth": "?string",
        "dropdownBg": "?string",
        "dropdownTextColor": "?string",
        "mobileBg": "?string",
        "mobileTextColor": "?string"
      }
    },
    "cta": {
      "type": "object",
      "required": false,
      "shape": {
        "label": "string",
        "url": "string"
      }
    }
  },
  "variants": null,
  "css_vars": [
    "--lx-accent-color"
  ],
  "parts": [
    "cart-badge",
    "cart-trigger",
    "cta",
    "dropdown",
    "dropdown-item",
    "link",
    "links",
    "logo",
    "mobile-link",
    "mobile-panel",
    "mobile-trigger",
    "root"
  ],
  "example": "<div data-island=\"Navbar\" data-props='{\"logo\":{\"src\":\"example-src\"},\"links\":[{\"label\":\"example-label\",\"url\":\"example-url\"}]}'></div>"
}
