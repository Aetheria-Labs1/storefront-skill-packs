{
  "name": "ReviewCarousel",
  "category": "social_proof",
  "usage_hint": "Rotating customer review showcase with star ratings, typically placed below product info or before FAQ on PDPs. Supports static reviews array or runtime fetch from our reviews API.",
  "when_to_use": "When you have 3+ customer reviews to display and want to build trust through social proof. Supports two modes: static reviews array (baked in) or fetch mode (reviewsEndpoint + productIds for live data from our API).",
  "when_not_to_use": "For single reviews (just show the review card directly). For real-time streaming review feeds (this fetches a batch, not a live stream).",
  "combine_with": [
    "TrustBadgeBar",
    "BuyBox",
    "PDPInfoCards",
    "FAQ"
  ],
  "anti_patterns": [
    "Passing more than 12 reviews in static mode (carousel becomes too long; pre-filter to top reviews by rating/helpfulness)",
    "Using minimal variant with long review bodies (text doesn't truncate well; use grid or default instead)",
    "Setting interval below 3000ms (users can't read reviews; keep it \u22654000ms)",
    "Mixing verified and unverified reviews without the verified flag (damages trust; always mark verified purchases)",
    "Using both reviews[] and reviewsEndpoint (reviews[] takes priority; pick one mode)"
  ],
  "examples": [
    {
      "label": "Default carousel with 4 reviews (autoplay, 5s interval)",
      "html": "<div data-island=\"ReviewCarousel\" data-props='{\"reviews\":[{\"author\":\"Sarah M.\",\"rating\":5,\"body\":\"Absolutely love this product! Quality exceeded my expectations and shipping was super fast.\",\"date\":\"2 weeks ago\",\"verified\":true},{\"author\":\"Mike R.\",\"rating\":4,\"body\":\"Great value for money. Minor issue with packaging but product itself is perfect.\",\"date\":\"1 month ago\",\"verified\":true},{\"author\":\"Emma L.\",\"rating\":5,\"body\":\"This is my third purchase. Consistent quality every time. Highly recommend!\",\"date\":\"3 days ago\",\"verified\":true,\"avatar\":\"/avatars/emma.jpg\"},{\"author\":\"David K.\",\"rating\":5,\"body\":\"Best decision I made this year. Customer service was also incredibly helpful.\",\"date\":\"1 week ago\",\"verified\":true}],\"autoplay\":true,\"interval\":5000,\"variant\":\"default\"}'></div>"
    },
    {
      "label": "Fetch mode \u2014 reviews from API endpoint filtered by product",
      "html": "<div data-island=\"ReviewCarousel\" data-props='{\"reviewsEndpoint\":\"/api/v1/storefront/public/reviews/abc12345\",\"productIds\":[\"gid://shopify/Product/8234567890\"],\"sort\":\"most_helpful\",\"minRating\":4,\"variant\":\"grid\"}'></div>"
    },
    {
      "label": "Grid layout showing all reviews at once (no autoplay)",
      "html": "<div data-island=\"ReviewCarousel\" data-props='{\"reviews\":[{\"author\":\"Sarah M.\",\"rating\":5,\"body\":\"Absolutely love this product! Quality exceeded my expectations and shipping was super fast.\",\"verified\":true},{\"author\":\"Mike R.\",\"rating\":4,\"body\":\"Great value for money. Minor issue with packaging but product itself is perfect.\",\"verified\":true},{\"author\":\"Emma L.\",\"rating\":5,\"body\":\"This is my third purchase. Consistent quality every time.\",\"verified\":true}],\"variant\":\"grid\"}'></div>"
    },
    {
      "label": "Compact horizontal strip for header/footer",
      "html": "<div data-island=\"ReviewCarousel\" data-props='{\"reviews\":[{\"author\":\"Sarah M.\",\"rating\":5,\"body\":\"Love it!\"},{\"author\":\"Mike R.\",\"rating\":4,\"body\":\"Great quality\"},{\"author\":\"Emma L.\",\"rating\":5,\"body\":\"Highly recommend\"},{\"author\":\"David K.\",\"rating\":5,\"body\":\"Perfect product\"}],\"variant\":\"compact\"}'></div>"
    }
  ],
  "props": {
    "reviews": {
      "type": "array",
      "required": false,
      "shape": {
        "author": "string",
        "rating": "number",
        "body": "string",
        "date": "?string",
        "verified": "?boolean",
        "avatar": "?string",
        "helpful_count": "?number"
      }
    },
    "reviewsEndpoint": {
      "type": "string",
      "required": false
    },
    "productIds": {
      "type": "array",
      "required": false
    },
    "minRating": {
      "type": "number",
      "required": false
    },
    "sort": {
      "type": "enum",
      "required": false,
      "values": [
        "recent",
        "highest",
        "most_helpful"
      ]
    },
    "pageSize": {
      "type": "number",
      "required": false,
      "default": "10"
    },
    "autoplay": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "interval": {
      "type": "number",
      "required": false,
      "default": "5000"
    },
    "variant": {
      "type": "enum",
      "required": false,
      "values": [
        "default",
        "compact",
        "grid",
        "minimal"
      ],
      "default": "default"
    }
  },
  "variants": [
    "default",
    "compact",
    "grid",
    "minimal"
  ],
  "css_vars": [
    "--lx-accent-color",
    "--lx-text-color"
  ],
  "parts": [
    "author",
    "avatar",
    "body",
    "card",
    "date",
    "dot",
    "dots",
    "load-more",
    "nav-next",
    "nav-prev",
    "root",
    "verified"
  ],
  "example": "<div data-island=\"ReviewCarousel\" data-props='{}'></div>"
}
