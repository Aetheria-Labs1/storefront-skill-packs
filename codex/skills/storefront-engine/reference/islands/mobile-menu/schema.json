{
  "name": "MobileMenu",
  "category": "navigation",
  "usage_hint": "Full-screen mobile navigation overlay with expandable sections and social links.",
  "when_to_use": "As a standalone mobile menu island when you need custom mobile navigation separate from desktop nav. Automatically opens on mount (controlled by parent). Supports nested link hierarchies with expand/collapse.",
  "when_not_to_use": "When Navbar or SiteHeader already provides mobile menu functionality (they have built-in mobile panels). Don't use both.",
  "combine_with": [
    "Navbar (as alternative mobile UI)",
    "Footer"
  ],
  "anti_patterns": [
    "Mounting MobileMenu without controlling isOpen state from parent \u2014 it defaults to open, so you must unmount when closed",
    "Using MobileMenu alongside Navbar's built-in mobile panel (data-lx-nav=\"mobile-panel\") \u2014 they conflict",
    "Passing deeply nested link structures (>2 levels) \u2014 mobile menu only supports parent + children, not grandchildren"
  ],
  "examples": [
    {
      "label": "Basic mobile menu with social links",
      "html": "<div data-island=\"MobileMenu\" data-props='{\"links\":[{\"label\":\"Shop\",\"url\":\"/shop\",\"children\":[{\"label\":\"New\",\"url\":\"/new\"},{\"label\":\"Sale\",\"url\":\"/sale\"}]},{\"label\":\"About\",\"url\":\"/about\"}],\"socials\":[{\"platform\":\"instagram\",\"url\":\"https://instagram.com/store\"},{\"platform\":\"twitter\",\"url\":\"https://twitter.com/store\"}],\"logo\":{\"src\":\"/logo.svg\",\"alt\":\"Store\"}}'></div>"
    },
    {
      "label": "Mobile menu with flat navigation",
      "html": "<div data-island=\"MobileMenu\" data-props='{\"links\":[{\"label\":\"Home\",\"url\":\"/\"},{\"label\":\"Products\",\"url\":\"/products\"},{\"label\":\"Contact\",\"url\":\"/contact\"}]}'></div>"
    },
    {
      "label": "Mobile menu with nested categories",
      "html": "<div data-island=\"MobileMenu\" data-props='{\"links\":[{\"label\":\"Clothing\",\"url\":\"#\",\"children\":[{\"label\":\"Tops\",\"url\":\"/tops\"},{\"label\":\"Bottoms\",\"url\":\"/bottoms\"},{\"label\":\"Dresses\",\"url\":\"/dresses\"}]},{\"label\":\"Accessories\",\"url\":\"#\",\"children\":[{\"label\":\"Bags\",\"url\":\"/bags\"},{\"label\":\"Jewelry\",\"url\":\"/jewelry\"}]}],\"logo\":{\"src\":\"/logo.svg\"}}'></div>"
    }
  ],
  "props": {
    "links": {
      "type": "array",
      "required": true,
      "shape": {
        "label": "string",
        "url": "string",
        "children": "?array<{label: string, url: string, children: ?array<{}>}>"
      }
    },
    "socials": {
      "type": "array",
      "required": false,
      "shape": {
        "platform": "string",
        "url": "string"
      }
    },
    "logo": {
      "type": "object",
      "required": false,
      "shape": {
        "src": "string",
        "alt": "?string"
      }
    }
  },
  "variants": null,
  "css_vars": [
    "--lx-accent-color",
    "--lx-text-color"
  ],
  "parts": [
    "close-btn",
    "header",
    "link",
    "root"
  ],
  "example": "<div data-island=\"MobileMenu\" data-props='{\"links\":[{\"label\":\"example-label\",\"url\":\"example-url\"}]}'></div>"
}
